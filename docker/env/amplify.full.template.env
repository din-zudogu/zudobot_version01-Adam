# =============================================================================
# Zudobot — Amplify environment template (NO SECRETS IN GIT)
# =============================================================================
# 1) Pull live values:  npm run clone:export-env
# 2) Copy output:       docker/env/generated/amplify.snapshot.env → docker/env/local.env
# 3) Fill any missing keys manually in AWS Amplify Console (branch: master)
# =============================================================================

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_URL=
NEXT_PUBLIC_PLATFORM_DOMAIN=
NEXT_PUBLIC_API_URL=
AUTH_TRUST_HOST=true
AUTH_URL=
NEXTAUTH_URL=
NODE_ENV=production

# ── MongoDB (Atlas) ───────────────────────────────────────────────────────────
MONGO_URI=
MONGO_URI_DIRECT=
MONGO_DB_NAME=
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_EXTENSION_OAUTH_CLIENT_ID=

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_API_KEY_LIVE=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_CLASSIFY_MODEL=gemini-2.5-flash
ENABLE_GEMINI_GOOGLE_SEARCH=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── Widget / CDN ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_WIDGET_CDN_URL=
NEXT_PUBLIC_WIDGET_VERSION=
NEXT_PUBLIC_WIDGET_SCRIPT_INTEGRITY=
NEXT_PUBLIC_ZUDOBOT_GLOBAL_WIDGET_SCRIPT_INTEGRITY=
WIDGET_SCRIPT_INTEGRITY=
NEXT_PUBLIC_ZUDOBOT_SITE_EMBED_KEY=
NEXT_PUBLIC_ZUDOBOT_SITE_WIDGET_POSITION=
NEXT_PUBLIC_ZUDOBOT_SITE_WIDGET_COLOR=
NEXT_PUBLIC_ZUDOBOT_WIDGET_EMBED_KEY=
NEXT_PUBLIC_CHROME_EXTENSION_ID=
NEXT_PUBLIC_CHROME_WEB_STORE_URL=

# ── Platform bot ──────────────────────────────────────────────────────────────
PLATFORM_GLOBAL_EMBED_KEY=
PLATFORM_BOT_EMBED_KEY=
PLATFORM_GLOBAL_CHAT_TENANT_ID=
ZUDO_GUIDE_EMBED_KEY=
ADMIN_TOTP_SECRET=
NEXT_PUBLIC_PLATFORM_KB_CORE_URLS=

# ── Security / cron ───────────────────────────────────────────────────────────
ZUDOBOT_MASTER_SECRET=
INTERNAL_CRON_SECRET=
PII_ENCRYPTION_KEY=
COMPANY_TAX_ID=

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase (optional) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API app (apps/api) ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=

# ── Sandbox limits ────────────────────────────────────────────────────────────
SANDBOX_IP_LIMIT_PER_HOUR=20
SANDBOX_SESSION_LIMIT=20
