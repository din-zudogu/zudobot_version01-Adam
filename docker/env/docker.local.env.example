# ====================================================================
# ZUDOBOT ENTERPRISE SAAS - SANDBOX ENVIRONMENT VARIABLE TEMPLATE
# ====================================================================
# COPY THIS FILE TO 'local.env' BEFORE RUNNING DOCKER CONTAINERS
# DO NOT COMMIT THE ACTUAL 'local.env' TO GITHUB REPOSITORIES

# Authentication Block
AUTH_SECRET=generate_a_random_32_character_string_here
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_32_character_string_here
AUTH_TRUST_HOST=true

# OAuth Provider Configuration
GOOGLE_CLIENT_ID=your_sandbox_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_sandbox_google_client_secret

# AI Processing Models (Gemini Integration)
GEMINI_API_KEY=your_sandbox_gemini_api_key_here
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Database Connectivity Configuration
# Production Atlas (for clone-mongodb.mjs --execute only)
MONGODB_PRODUCTION_URI=mongodb+srv://user:pass@production-cluster.mongodb.net/zudobot
# Local Docker sandbox (web-scaffold + compose)
MONGO_URI=mongodb://root:localsecretpassword@localhost:27017/zudobot?authSource=admin

# App URLs (sandbox)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NODE_ENV=development
