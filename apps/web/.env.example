# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://zudobot.zudogu.com
NEXT_PUBLIC_URL=https://zudobot.zudogu.com
NEXT_PUBLIC_PLATFORM_DOMAIN=zudobot.zudogu.com
AUTH_TRUST_HOST=true

# ── Database ──────────────────────────────────────────────────────────────────
# Password may contain special chars (@, $, ^) — store raw value, app encodes automatically
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=<appname>
MONGO_URI_DIRECT=mongodb://<user>:<pass>@<shard0>,<shard1>,<shard2>/?ssl=true&replicaSet=<rs>&authSource=admin&appName=<appname>
# Windows scripts: use Google DNS for Atlas SRV if ISP blocks querySrv (optional)
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Local dev from Amplify (no .env.local required):
#   set ACCESS_KEY_ID / SECRET_ACCESS_KEY (IAM user with amplify:GetBranch)
#   npm run dev:amplify

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
AUTH_URL=https://zudobot.zudogu.com
AUTH_SECRET=                             # openssl rand -base64 32

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Chrome Extension OAuth client ID (Path 2) — same as manifest oauth2.client_id
GOOGLE_EXTENSION_OAUTH_CLIENT_ID=
# SRI สำหรับ widget.js (server API — ถ้าไม่ตั้ง ระบบคำนวณจาก public/widget.js อัตโนมัติ)
WIDGET_SCRIPT_INTEGRITY=

# Chrome Web Store (Path 2 — ตั้งโดยทีม Zudobot ลูกค้าไม่ต้องยุ่ง)
NEXT_PUBLIC_CHROME_EXTENSION_ID=
# ลิงก์ร้านเต็ม ใช้ได้ก่อนมี Extension ID
NEXT_PUBLIC_GOOGLE_EXTENSION_URL=

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004
# Set to "true" on Amplify only when the API key supports Google Search grounding
ENABLE_GEMINI_GOOGLE_SEARCH=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@zudogu.com

# ── Widget CDN ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WIDGET_CDN_URL=https://cdn.zudogu.com/zudobot
NEXT_PUBLIC_WIDGET_VERSION=v1

# ── Article Webhook (from admin.zudogu.com) ───────────────────────────────────
WEBHOOK_SECRET=                         # ต้องตรงกับ WEBHOOK_SECRET ของ zudogu-admin

# ── Internal ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.zudogu.com
ZUDOBOT_MASTER_SECRET=                  # openssl rand -hex 32
INTERNAL_CRON_SECRET=                   # openssl rand -hex 32
COMPANY_TAX_ID=

# ── PII Encryption (AES-256-GCM) ─────────────────────────────────────────────
# REQUIRED for Partner Profile + Client Data encryption (national ID, tax ID, phone, email)
# Generate: openssl rand -hex 32   (must be exactly 64 hex chars = 32 bytes)
PII_ENCRYPTION_KEY=                     # openssl rand -hex 32

# ── Zudo Guide (in-dashboard support bot) ─────────────────────────────────────
# Run: node scripts/seed-zudo-guide.mjs  →  copy the generated key here
ZUDO_GUIDE_EMBED_KEY=internal_zg_...
# Marketing site widget (zudobot.zudogu.com) — matches dashboard embed snippet
NEXT_PUBLIC_ZUDOBOT_SITE_EMBED_KEY=4cd9beb1aca36902c7fa9ca0c7d04686
NEXT_PUBLIC_ZUDOBOT_SITE_WIDGET_POSITION=bottom-left
NEXT_PUBLIC_ZUDOBOT_SITE_WIDGET_COLOR=#1E5BC6
# Legacy alias
NEXT_PUBLIC_ZUDOBOT_WIDGET_EMBED_KEY=
# Admin → Knowledge Base → manual "Sync Platform Core KB" (comma-separated, no spaces required)
NEXT_PUBLIC_PLATFORM_KB_CORE_URLS=https://zudobot.zudogu.com/,https://zudobot.zudogu.com/pricing,https://zudobot.zudogu.com/privacy,https://zudobot.zudogu.com/terms
# Universal external embed (WordPress, Shopify, etc.) — admin /admin/zudobot + widget-init
# New name (preferred). Legacy PLATFORM_BOT_EMBED_KEY still read if this is unset.
PLATFORM_GLOBAL_EMBED_KEY=
# Legacy Amplify name — optional if PLATFORM_GLOBAL_EMBED_KEY is set
PLATFORM_BOT_EMBED_KEY=
PLATFORM_GLOBAL_CHAT_TENANT_ID=
# Step-up TOTP (Google Authenticator) for saving global bot config / whitelist
ADMIN_TOTP_SECRET=
